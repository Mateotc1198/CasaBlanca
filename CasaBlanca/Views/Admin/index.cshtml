@model CasaBlanca.Models.AdminDashboard

@{
    ViewBag.Title = "Panel Administrador";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="page-shell p-4 p-md-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="text-primary fw-bold mb-1">Panel de Administrador</h2>
                <p class="text-muted mb-0">Resumen general del sistema Casa Blanca.</p>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow rounded-4 h-100">
                    <div class="card-body p-4">
                        <h6 class="text-muted">Usuarios</h6>
                        <h2 class="fw-bold text-primary">@Model.TotalUsuarios</h2>
                        <p class="mb-0 text-muted">Registrados en el sistema</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow rounded-4 h-100">
                    <div class="card-body p-4">
                        <h6 class="text-muted">Reservas</h6>
                        <h2 class="fw-bold text-success">@Model.TotalReservas</h2>
                        <p class="mb-0 text-muted">Total realizadas</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow rounded-4 h-100">
                    <div class="card-body p-4">
                        <h6 class="text-muted">Pendientes</h6>
                        <h2 class="fw-bold text-warning">@Model.ReservasPendientes</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow rounded-4 h-100">
                    <div class="card-body p-4">
                        <h6 class="text-muted">Confirmadas</h6>
                        <h2 class="fw-bold text-success">@Model.ReservasConfirmadas</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow rounded-4 h-100">
                    <div class="card-body p-4">
                        <h6 class="text-muted">Canceladas</h6>
                        <h2 class="fw-bold text-danger">@Model.ReservasCanceladas</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-6">
                <div class="card shadow border-0 rounded-4 h-100">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">Gestión de usuarios</h4>
                        <p class="text-muted">Consulta los usuarios registrados y su rol dentro del sistema.</p>
                        <a href="/Admin/Usuarios" class="btn btn-outline-primary">Ver usuarios</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card shadow border-0 rounded-4 h-100">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">Gestión de reservas</h4>
                        <p class="text-muted">Consulta reservas, cambia estados y administra la información.</p>
                        <a href="/Admin/Reservas" class="btn btn-outline-success">Ver reservas</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card shadow border-0 rounded-4 h-100">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">Gestión de hoteles</h4>
                        <p class="text-muted">Crea, edita y controla los hoteles visibles en el sistema.</p>
                        <a href="/Admin/Hoteles" class="btn btn-outline-warning">Ver hoteles</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
