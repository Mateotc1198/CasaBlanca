@model CasaBlanca.Models.Hotel

@{
    ViewBag.Title = "Editar Hotel";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="page-shell p-4 p-md-5">
        <h2 class="fw-bold mb-4 page-title-light">Editar hotel</h2>

        <div class="card shadow border-0 rounded-4">
            <div class="card-body p-4">
                @if (ViewBag.MensajeError != null)
                {
                    <div class="alert alert-danger">@ViewBag.MensajeError</div>
                }

                @using (Html.BeginForm())
                {
                    @Html.HiddenFor(m => m.IdHotel)

                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ciudad</label>
                        @Html.TextBoxFor(m => m.Ciudad, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Ciudad, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Precio por noche</label>
                        @Html.TextBoxFor(m => m.PrecioPorNoche, new { @class = "form-control", type = "number", step = "0.01" })
                        @Html.ValidationMessageFor(m => m.PrecioPorNoche, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Capacidad máxima</label>
                        @Html.TextBoxFor(m => m.CapacidadMaxima, new { @class = "form-control", type = "number" })
                        @Html.ValidationMessageFor(m => m.CapacidadMaxima, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Imagen</label>
                        @Html.TextBoxFor(m => m.Imagen, new { @class = "form-control" })
                    </div>

                    <div class="form-check mb-4">
                        @Html.CheckBoxFor(m => m.Activo, new { @class = "form-check-input" })
                        <label class="form-check-label">Activo</label>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary">Guardar cambios</button>
                        <a href="/Admin/Hoteles" class="btn btn-outline-secondary">Volver</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
