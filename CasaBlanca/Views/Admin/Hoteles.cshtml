@model List<CasaBlanca.Models.Hotel>

@{
    ViewBag.Title = "Hoteles";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="page-shell p-4 p-md-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0 page-title-light">Gestión de hoteles</h2>
            <a href="/Admin/CrearHotel" class="btn btn-primary">Nuevo hotel</a>
        </div>

        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success">@TempData["MensajeExito"]</div>
        }

        <div class="card shadow border-0 rounded-4">
            <div class="card-body table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Hotel</th>
                            <th>Ciudad</th>
                            <th>Precio/Noche</th>
                            <th>Capacidad</th>
                            <th>Activo</th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in Model)
                        {
                            <tr>
                                <td>@h.IdHotel</td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrEmpty(h.Imagen))
                                        {
                                            <img src="~/Content/Imagenes/@h.Imagen"
                                                 alt="@h.Nombre"
                                                 style="width:70px; height:55px; object-fit:cover; border-radius:10px;" />
                                        }
                                        <span class="fw-bold">@h.Nombre</span>
                                    </div>
                                </td>
                                <td>@h.Ciudad</td>
                                <td>$@h.PrecioPorNoche.ToString("N2")</td>
                                <td>@h.CapacidadMaxima</td>
                                <td>@(h.Activo ? "Sí" : "No")</td>
                                <td>
                                    <a href="/Admin/EditarHotel/@h.IdHotel" class="btn btn-sm btn-outline-primary">Editar</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
