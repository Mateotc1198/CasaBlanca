@{
    ViewBag.Title = "Iniciar Sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="page-shell p-3 p-md-4">
                <div class="card shadow border-0 rounded-4">
                    <div class="card-header bg-primary text-white text-center">
                        <h4>Iniciar Sesión</h4>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(ViewBag.MensajeError))
                        {
                            <div class="alert alert-danger">@ViewBag.MensajeError</div>
                        }

                        <form method="post" action="/Usuario/Login">
                            <div class="mb-3">
                                <label class="form-label">Usuario</label>
                                <input type="text" name="user" class="form-control" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Contraseña</label>
                                <input type="password" name="clave" class="form-control" required />
                            </div>

                            <button type="submit" class="btn btn-primary w-100">Ingresar</button>
                            <a href="/Usuario/Registrar" class="btn btn-link mt-2 w-100 text-center">¿No tienes cuenta? Regístrate</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

